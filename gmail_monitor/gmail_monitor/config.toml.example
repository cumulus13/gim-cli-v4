# Database Configuration
[database]
host = "192.168.108.212"
port = 5432
database = "gim"
user = "gim_admin"
password = "fuckme"

# Growl Notification Settings
[growl]
host = "localhost"
port     = 23053
password = ""  # Leave empty if no password

# Monitoring Settings
[monitoring]
check_interval = 30  # Check every 45 seconds
max_emails_per_check = 10  # Maximum emails to fetch per check
reconnect_delay       = 30   # seconds to wait before reconnect attempt
max_reconnect_attempts = 5   # 0 = unlimited

[logging]
level = "INFO"          # DEBUG | INFO | WARNING | ERROR
file  = "gmail_monitor.log"
